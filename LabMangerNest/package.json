{
  "name": "labmanger-nest",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "prisma:generate": "npx prisma generate --schema prisma/user.prisma && npx prisma generate --schema prisma/manger.prisma && npx prisma generate --schema prisma/PatientTest.prisma",
    "prisma:migrate": "npx prisma db push --schema prisma/user.prisma --url \"file:./prisma/user.db\" && npx prisma db push --schema prisma/manger.prisma --url \"file:./prisma/manger.db\" && npx prisma db push --schema prisma/PatientTest.prisma --url \"file:./prisma/PatientTest.db\"",
    "prisma:build": "npm run prisma:generate && npm run prisma:migrate",
    "build": "nest build",
    "start": "nest start",
    "dev": "nest start --watch",
    "debug": "nest start --debug --watch",
    "prod": "cross-env NODE_ENV=production node dist/src/main.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@nestjs/common": "^11.1.21",
    "@nestjs/core": "^11.1.21",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.21",
    "@nestjs/schedule": "^6.1.3",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@valentynb/gs1-parser": "^2.0.0",
    "better-sqlite3": "^12.10.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@types/node": "^24.12.4",
    "@types/passport-jwt": "^4.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}

